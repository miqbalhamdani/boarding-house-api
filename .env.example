# Application
ENV=development
PORT=8080
LOG_LEVEL=info

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/go_backend?sslmode=disable

# Auth / JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_HOURS=720

# Payment gateway
# The MVP ships a self-contained "sandbox" provider so the tenant Pay Now flow
# works without external credentials. Swap PAYMENT_GATEWAY_PROVIDER for a real
# provider (midtrans, xendit, …) when integrating the payment-gateway module.
PAYMENT_GATEWAY_PROVIDER=sandbox
PAYMENT_GATEWAY_CHECKOUT_BASE_URL=https://sandbox.pay.local/checkout
PAYMENT_GATEWAY_RETURN_URL=https://app.example.com/tenant/payment-result
PAYMENT_GATEWAY_CHECKOUT_TTL_HOURS=24

# Object storage for payment-proof files (Module 10).
# Local dev uses the MinIO service in docker-compose. The bucket is PRIVATE;
# proof files are served via short-lived presigned URLs only.
# Production MUST override these with real, private credentials.
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=payment-proofs
STORAGE_USE_SSL=false
STORAGE_PROOF_PRESIGN_TTL_MINUTES=15
